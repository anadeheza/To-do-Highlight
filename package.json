{
  "name": "to-do-highlighter",
  "displayName": "to-do highlighter",
  "description": "Highlights unfulfilled tasks with various colors , simple to use and pretty useful",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Todo Highlighter",
      "properties": {
        "todoHighlighter.keywords": {
          "type": "array",
          "default": [
            {"word": "TODO", "color": "rgba(255, 200, 0, 0.3)"},
            {"word": "FIXME", "color": "rgba(255, 80, 80, 0.3)"},
            {"word": "HACK", "color": "rgba(0, 200, 100, 0.3)"},
            {"word": "NOTE", "color": "rgba(100, 150, 255, 0.3)"},
            {"word": "WARN", "color": "rgba(255, 140, 0, 0.3)"}
          ],
          "description": "Lists of highlighted keywords"
        },
        "todoHighlighter.commentsOnly": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, only hifhlight the comments, not the code itself"
        },
        "todoHighlighter.searchWord": {
          "type": "string",
          "default": "",
          "description": "Temporarily highlight a custom word across the files"
        }
      }
    },
    
    "commands": [
      {
        "command": "to-do-highlighter.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "todoHighlighter.jumpToNext",
        "title": "Jump to Next TODO"
      },
      {
        "command": "todoHighlighter.showSummary",
        "title": "Todo Highlighter: Show Summary"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
